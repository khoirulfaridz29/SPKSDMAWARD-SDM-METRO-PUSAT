{
  "version": 2,
  "buildCommand": "composer install --no-dev --optimize-autoloader && npm install && npm run build",
  "outputDirectory": "public",
  "functions": {
    "public/index.php": {
      "runtime": "vercel-php@0.7.0",
      "includeFiles": [
        "app/**",
        "bootstrap/**",
        "config/**",
        "database/**",
        "public/**",
        "resources/**",
        "routes/**",
        "storage/**",
        "vendor/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
